  "keyFeatures": [
    "Multi-role system with Admin, Lecturer, and Student dashboards",
    "Course enrollment with prerequisite checking and waitlist management",
    "Attendance tracking and real-time grade management",
    "Fee structures, invoicing, and payment processing",
    "Degree progress tracking and transcript generation",
    "Accommodation (hostel) allocation and management",
    "Continuous assessment and results moderation workflow",
    "Academic calendar and timetable management",
    "Bulk import for students, teachers, and course data",
    "Document request system with downloadable forms"
  ],
  "publicApiSurface": [
    "POST /api/auth/login",
